#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * byjesper-guidelines — publish & compose shared AI coding guidelines.
 *
 * Commands:
 *   sync --profile=apps|packages [--check]
 *       Publish this package's `common` + `<profile>` fragments into the
 *       consuming repo's .ai/guidelines/shared/ (a managed directory: wiped and
 *       rewritten each run). Your own fragments live elsewhere under
 *       .ai/guidelines/ and are never touched.
 *       After sync: apps run `php artisan boost:update`; libraries run
 *       `byjesper-guidelines build`.
 *
 *   build [--check]
 *       Compose every .ai/guidelines/**\/*.md (shared + local), sorted by
 *       filename, into CLAUDE.md and AGENTS.md. For repos that do not use Boost.
 *
 *   --check exits non-zero if the target is out of date (for CI).
 */

$argv = $_SERVER['argv'];
$cmd = $argv[1] ?? '';
$args = array_slice($argv, 2);
$check = in_array('--check', $args, true);
$root = getcwd();
$pkg = __DIR__.'/../guidelines';

$fail = static function (string $msg): never {
    fwrite(STDERR, $msg."\n");
    exit(1);
};

$listMd = static function (string $dir): array {
    if (! is_dir($dir)) {
        return [];
    }
    $out = [];
    $it = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($dir, FilesystemIterator::SKIP_DOTS)
    );
    foreach ($it as $file) {
        if ($file->isFile() && $file->getExtension() === 'md') {
            $out[] = $file->getPathname();
        }
    }

    return $out;
};

if ($cmd === 'sync') {
    $profile = 'packages';
    foreach ($args as $a) {
        if (str_starts_with($a, '--profile=')) {
            $profile = substr($a, strlen('--profile='));
        }
    }
    $profiles = array_map('basename', array_filter(
        glob($pkg.'/*', GLOB_ONLYDIR) ?: [],
        static fn (string $d): bool => basename($d) !== 'common',
    ));
    if (! in_array($profile, $profiles, true)) {
        $fail("Unknown profile '{$profile}'. Available: ".implode(', ', $profiles));
    }

    $sources = [];
    foreach (['common', $profile] as $group) {
        foreach ($listMd($pkg.'/'.$group) as $f) {
            $sources[basename($f)] = (string) file_get_contents($f);
        }
    }
    ksort($sources);

    $sharedDir = $root.'/.ai/guidelines/shared';

    if ($check) {
        $current = [];
        foreach ($listMd($sharedDir) as $f) {
            $current[basename($f)] = (string) file_get_contents($f);
        }
        ksort($current);
        if ($current !== $sources) {
            $fail('.ai/guidelines/shared is out of date. Run `composer guidelines:sync`.');
        }
        echo "Shared guidelines in sync (profile: {$profile}).\n";
        exit(0);
    }

    if (is_dir($sharedDir)) {
        foreach (glob($sharedDir.'/*.md') ?: [] as $f) {
            unlink($f);
        }
    } else {
        mkdir($sharedDir, 0o777, true);
    }
    foreach ($sources as $name => $content) {
        file_put_contents($sharedDir.'/'.$name, $content);
    }
    echo 'Synced '.count($sources)." fragments to .ai/guidelines/shared (profile: {$profile}).\n";
    exit(0);
}

if ($cmd === 'build') {
    $files = $listMd($root.'/.ai/guidelines');
    usort($files, static fn (string $a, string $b): int => strcmp(basename($a), basename($b)));
    if ($files === []) {
        $fail('No fragments found under .ai/guidelines/. Run `composer guidelines:sync` first.');
    }

    $banner = <<<'TXT'
        <!--
          GENERATED FILE — DO NOT EDIT.
          Composed from .ai/guidelines/ by `composer guidelines:build`.
          Shared fragments live in .ai/guidelines/shared/ (managed by `guidelines:sync`).
        -->
        TXT;

    $body = $banner."\n\n".implode("\n\n", array_map(
        static fn (string $f): string => rtrim((string) file_get_contents($f)),
        $files,
    ))."\n";

    $targets = ['CLAUDE.md', 'AGENTS.md'];
    $stale = [];
    foreach ($targets as $t) {
        $p = $root.'/'.$t;
        $cur = is_file($p) ? file_get_contents($p) : null;
        if ($cur !== $body) {
            $stale[] = $t;
            if (! $check) {
                file_put_contents($p, $body);
            }
        }
    }

    if ($check) {
        if ($stale !== []) {
            $fail('Out of date: '.implode(', ', $stale).'. Run `composer guidelines:build`.');
        }
        echo "CLAUDE.md / AGENTS.md up to date.\n";
        exit(0);
    }
    echo 'Wrote '.implode(', ', $targets).' ('.count($files)." fragments).\n";
    exit(0);
}

$fail("Usage:\n  byjesper-guidelines sync --profile=apps|packages [--check]\n  byjesper-guidelines build [--check]");
